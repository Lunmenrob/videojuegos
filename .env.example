# Variables de entorno para la aplicación
# Copia este archivo a .env y configura los valores según tu entorno

# Configuración de la base de datos
DB_HOST=localhost
DB_NAME=videojuegos
DB_USER=root
DB_PASS=

# Nota: Si no se configuran estas variables, se usarán los valores por defecto:
# DB_HOST: localhost
# DB_NAME: videojuegos
# DB_USER: root
# DB_PASS: (vacío)

# Para producción, configura estos valores en tu servidor web o en un archivo .env
# Ejemplo para Apache:
# SetEnv DB_HOST production-db-server
# SetEnv DB_NAME production_db
# SetEnv DB_USER production_user
# SetEnv DB_PASS secure_password
